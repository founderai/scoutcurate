{
  "name": "scoutcurate",
  "displayName": "ScoutCurate - AI Gift Finder",
  "version": "1.0.0",
  "description": "Scout finds gifts for kids. Curate finds gifts for adults. AI-powered, Amazon affiliate-linked.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "lucide-react": "0.438.0",
    "openai": "4.52.7",
    "plasmo": "0.89.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/chrome": "0.0.270",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.40",
    "svgo": "^3.3.3",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "ScoutCurate - AI Gift Finder",
    "description": "AI-powered gift ideas for kids (Scout) and adults (Curate). Speak or type a description, get 25 Amazon gift suggestions instantly.",
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://api.openai.com/*"
    ]
  }
}
